{
  "name": "@unsearch/mcp-server",
  "version": "0.1.0",
  "description": "UnSearch MCP server — verifiable web retrieval for AI agents.",
  "license": "Apache-2.0",
  "repository": "github:Rakesh1002/unsearch",
  "homepage": "https://unsearch.dev",
  "type": "module",
  "bin": {
    "unsearch-mcp-server": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts src/bin.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@unsearch/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=18" }
}
