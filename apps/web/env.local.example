# Frontend Environment Variables Example
# Copy this file to .env.local and update with your values

# API Configuration (REQUIRED)
NEXT_PUBLIC_API_URL=http://localhost:8000
# For production: https://api.yourdomain.com or https://your-app.railway.app

# App Configuration (REQUIRED)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production: https://app.yourdomain.com or https://your-app.vercel.app

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# Feature Flags (Optional)
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_DOCS=true
NEXT_PUBLIC_ENABLE_WEBHOOKS=false

# Stripe (Optional - for embedded checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Support (Optional)
NEXT_PUBLIC_SUPPORT_EMAIL=support@unsearch.dev
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/...
