# UnSearch API Configuration
# Copy this file to .env and update the values for your environment

# ====================
# Application Settings
# ====================
APP_NAME="UnSearch API"
VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG="false"
LOG_LEVEL="INFO"

# ====================
# API Configuration
# ====================
HOST="0.0.0.0"
PORT="8000"
WORKERS="4"
API_PREFIX="/api/v1"
DOCS_URL="/docs"
OPENAPI_URL="/openapi.json"

# ====================
# Security Settings
# ====================
API_KEYS=""
API_KEY_HEADER="X-API-Key"
SECRET_KEY=""
ALLOWED_ORIGINS="*"
CORS_CREDENTIALS="true"

# ====================
# SearXNG Configuration
# ====================
SEARXNG_URL="http://localhost:8080"
SEARXNG_TIMEOUT="10"
SEARXNG_MAX_RETRIES="3"
SEARXNG_ENABLED_ENGINES="google,bing,duckduckgo"

# ====================
# Redis Configuration
# ====================
REDIS_URL="redis://localhost:6379"
REDIS_MAX_CONNECTIONS="20"
CACHE_DEFAULT_TTL="3600"
CACHE_COMPRESSION="true"

# ====================
# PostgreSQL Database
# ====================
DATABASE_URL="postgresql://user:pass@localhost:5432/UnSearch"
DATABASE_POOL_SIZE="10"
DATABASE_MAX_OVERFLOW="20"
DATABASE_POOL_TIMEOUT="30"
DATABASE_ECHO="false"

# ====================
# Celery Configuration
# ====================
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TASK_SOFT_TIME_LIMIT="300"
CELERY_TASK_TIME_LIMIT="600"
CELERY_WORKER_CONCURRENCY="4"

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_DEFAULT="10/minute"  # Free tier default (10 req/min)
RATE_LIMIT_BURST="20"

# ====================
# Scraping Configuration
# ====================
SCRAPING_MAX_CONCURRENT="10"
SCRAPING_TIMEOUT="30"
SCRAPING_USER_AGENT="UnSearch-API/1.0"
SCRAPING_RESPECT_ROBOTS_TXT="true"
SCRAPING_DEFAULT_DELAY="1"
SCRAPING_JAVASCRIPT_ENABLED="false"  # Enable Playwright fallback for JS-heavy pages

# ====================
# RAG / Embeddings Configuration
# ====================
# OpenAI API for embeddings (or compatible API)
OPENAI_API_KEY=""
EMBEDDING_API_URL="https://api.openai.com/v1"
EMBEDDING_MODEL="text-embedding-3-small"

# ====================
# Cloudflare Workers AI (50K credits available)
# ====================
# Get credentials from: https://dash.cloudflare.com/
# Account ID: Dashboard > Workers & Pages > Overview (right sidebar)
# API Token: Create at https://dash.cloudflare.com/profile/api-tokens
#   - Use "Workers AI" template or custom with "Workers AI - Run" permission
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_AI_ENABLED="true"

# ---- ENTERPRISE MODEL SELECTION ----
# See full catalog: https://developers.cloudflare.com/workers-ai/models/

# EMBEDDINGS (critical for RAG quality)
# Enterprise (multilingual): @cf/baai/bge-m3 (100+ languages, hybrid dense+sparse)
# Google's latest: @cf/google/embeddinggemma-300m (100+ languages, state-of-the-art)
# English quality: @cf/baai/bge-large-en-v1.5 (1024 dims)
# English fast: @cf/baai/bge-base-en-v1.5 (768 dims)
CLOUDFLARE_EMBEDDING_MODEL="@cf/baai/bge-m3"

# PRIMARY LLM (for answer generation)
# Enterprise production: @cf/openai/gpt-oss-120b (OpenAI open-weight, highest reasoning)
# Quality + Speed: @cf/meta/llama-3.3-70b-instruct-fp8-fast (RECOMMENDED - great balance)
# Latest Llama 4: @cf/meta/llama-4-scout-17b-16e-instruct (MoE, multimodal)
# RAG-optimized: @cf/ibm/granite-4.0-h-micro (IBM, specifically for RAG)
# Fast: @cf/meta/llama-3.1-8b-instruct-fast (simple queries)
CLOUDFLARE_LLM_MODEL="@cf/meta/llama-3.3-70b-instruct-fp8-fast"

# REASONING MODEL (for complex analytical queries)
# Primary: @cf/qwen/qwq-32b (competitive with DeepSeek-R1, o1-mini)
# Alternative: @cf/deepseek/deepseek-r1-distill-qwen-32b (state-of-the-art reasoning)
CLOUDFLARE_REASONING_MODEL="@cf/qwen/qwq-32b"

# RERANKER (for result ranking - only one available)
CLOUDFLARE_RERANKER_MODEL="@cf/baai/bge-reranker-base"

# CONTENT SAFETY (enterprise requirement)
# @cf/meta/llama-guard-3-8b - for prompt/response safety classification
CLOUDFLARE_SAFETY_MODEL="@cf/meta/llama-guard-3-8b"

# ====================
# Multi-Provider Search Fallback
# ====================
# Configure additional search providers for automatic fallback
# SearXNG is always the primary provider (free, self-hosted)
SERPER_API_KEY=""  # https://serper.dev
SEARCHAPI_KEY=""   # https://searchapi.io
GOOGLE_CSE_API_KEY=""  # Google Custom Search Engine
GOOGLE_CSE_CX=""       # Google CSE ID

# ====================
# Monitoring & Metrics
# ====================
ENABLE_METRICS="true"
PROMETHEUS_PORT="9090"
ENABLE_TRACING="false"

# ====================
# Analytics & Monitoring
# ====================
# PostHog (Product Analytics) - https://posthog.com
# Required for PMF measurement and user analytics
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"  # or your self-hosted instance

# Sentry (Error Tracking) - https://sentry.io
SENTRY_DSN=""

# ====================
# Email Service
# ====================
# Resend (Email API) - https://resend.com
# 3,000 emails/month free tier; verify your domain in Resend dashboard
RESEND_API_KEY=""
EMAIL_FROM="noreply@unsearch.dev"
EMAIL_REPLY_TO="support@unsearch.dev"
# Base URL of the frontend (for verification/reset links in emails)
FRONTEND_URL="http://localhost:3000"

# ====================
# External Services
# ====================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# ====================
# Stripe Billing
# ====================
# Get keys from: https://dashboard.stripe.com/apikeys
# Create products/prices with: python scripts/setup_stripe_plans.py
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""  # Create webhook endpoint at /api/v1/billing/webhook/stripe

# Pricing Tiers:
# - Free: $0/mo - 5,000 queries, 500 scrapes
# - Pro: $19/mo ($190/yr) - 25,000 queries, 5,000 scrapes
# - Growth: $49/mo ($490/yr) - 100,000 queries, 25,000 scrapes
# - Scale: $149/mo ($1,490/yr) - 500,000 queries, 100,000 scrapes
# Yearly = 17% discount (2 months free)

# Pro Plan - $19/mo ($190/yr)
STRIPE_PRO_PRODUCT_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# Growth Plan - $49/mo ($490/yr)
STRIPE_GROWTH_PRODUCT_ID=""
STRIPE_GROWTH_MONTHLY_PRICE_ID=""
STRIPE_GROWTH_YEARLY_PRICE_ID=""

# Scale Plan - $149/mo ($1490/yr)
STRIPE_SCALE_PRODUCT_ID=""
STRIPE_SCALE_MONTHLY_PRICE_ID=""
STRIPE_SCALE_YEARLY_PRICE_ID=""

# ====================
# OAuth Providers (Optional - for social login)
# ====================
# Google OAuth: https://console.cloud.google.com/apis/credentials
# Callback URL: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth: https://github.com/settings/developers
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ====================
# Production Configuration
# ====================
# For production deployment (Railway, Fly.io, etc.)
API_URL="https://api.unsearch.dev"
WEB_URL="https://unsearch.dev"

# Generate a strong secret key for JWT tokens
# Run: openssl rand -hex 32
SECRET_KEY="CHANGE-THIS-IN-PRODUCTION-use-openssl-rand-hex-32"

# Production security settings
ALLOWED_ORIGINS="https://unsearch.dev,https://www.unsearch.dev"
TRUSTED_HOSTS="api.unsearch.dev"

# ====================
# Feature Flags
# ====================
# Enable/disable features
ZERO_RETENTION_MODE="false"  # Set to true for privacy-first mode
ENABLE_NEURAL_SEARCH="true"  # Exa-compatible features
ENABLE_KNOWLEDGE_GRAPH="true"  # Glean-compatible features
ENABLE_MONITORING="true"  # Topic monitoring features
ENABLE_VERIFICATION="true"  # Fact verification features
