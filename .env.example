# UnSearch API Configuration
# Copy this file to .env and update the values for your environment

# ====================
# Application Settings
# ====================
APP_NAME="UnSearch API"
VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG="false"
LOG_LEVEL="INFO"

# ====================
# API Configuration
# ====================
HOST="0.0.0.0"
PORT="8000"
WORKERS="4"
API_PREFIX="/api/v1"
DOCS_URL="/docs"
OPENAPI_URL="/openapi.json"

# ====================
# Security Settings
# ====================
API_KEYS=""
API_KEY_HEADER="X-API-Key"
SECRET_KEY=""
CORS_ORIGINS="*"
CORS_CREDENTIALS="true"

# ====================
# SearXNG Configuration
# ====================
SEARXNG_URL="http://localhost:8080"
SEARXNG_TIMEOUT="10"
SEARXNG_MAX_RETRIES="3"
SEARXNG_ENABLED_ENGINES="google,bing,duckduckgo"

# ====================
# Redis Configuration
# ====================
REDIS_URL="redis://localhost:6379"
REDIS_MAX_CONNECTIONS="20"
CACHE_DEFAULT_TTL="3600"
CACHE_COMPRESSION="true"

# ====================
# PostgreSQL Database
# ====================
DATABASE_URL="postgresql://user:pass@localhost:5432/UnSearch"
DATABASE_POOL_SIZE="10"
DATABASE_MAX_OVERFLOW="20"
DATABASE_POOL_TIMEOUT="30"
DATABASE_ECHO="false"

# ====================
# Celery Configuration
# ====================
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TASK_SOFT_TIME_LIMIT="300"
CELERY_TASK_TIME_LIMIT="600"
CELERY_WORKER_CONCURRENCY="4"

# ====================
# Rate Limiting
# ====================
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_DEFAULT="1000/hour"
RATE_LIMIT_BURST="100"

# ====================
# Scraping Configuration
# ====================
SCRAPING_MAX_CONCURRENT="10"
SCRAPING_TIMEOUT="30"
SCRAPING_USER_AGENT="UnSearch-API/1.0"
SCRAPING_RESPECT_ROBOTS_TXT="true"
SCRAPING_DEFAULT_DELAY="1"

# ====================
# Monitoring & Metrics
# ====================
ENABLE_METRICS="true"
PROMETHEUS_PORT="9090"
ENABLE_TRACING="false"

# ====================
# External Services
# ====================
SENTRY_DSN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
